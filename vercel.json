{
  "installCommand": "npm install --legacy-peer-deps",
  "crons": [
    {
      "path": "/api/cron/morning-briefing",
      "schedule": "0 14 * * 1-5"
    },
    {
      "path": "/api/cron/nightly-report",
      "schedule": "0 1 * * 1-5"
    },
    {
      "path": "/api/cron/audit-sweep",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/sol-monitor",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/daily-sync",
      "schedule": "0 16 * * *"
    }
  ],
  "functions": {
    "app/api/**": {
      "maxDuration": 60
    }
  }
}