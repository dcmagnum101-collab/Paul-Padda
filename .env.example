# =============================================================================
# SUPABASE — PostgreSQL database
# Get these from: Supabase Dashboard → Project → Settings → Database
# =============================================================================

# Pooled connection (via pgbouncer) — used by Prisma at runtime on Vercel
# Found under: Connection Pooling → Connection string (Transaction mode)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection — used by Prisma for migrations
# Found under: Connection string (Session mode / Direct)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# =============================================================================
# ANTHROPIC (AI features)
# =============================================================================
ANTHROPIC_API_KEY="sk-ant-"

# =============================================================================
# RESEND (email delivery)
# Create at: https://resend.com
# =============================================================================
RESEND_API_KEY="re_"
RESEND_FROM_EMAIL="briefings@paddalaw.ai"

# =============================================================================
# TWILIO (SMS notifications)
# =============================================================================
TWILIO_ACCOUNT_SID="AC"
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER="+1"

# =============================================================================
# VERCEL CRON SECURITY
# Any random string — must match what Vercel sends as Bearer token
# Generate with: openssl rand -hex 32
# =============================================================================
CRON_SECRET=""

# =============================================================================
# APP URL (set to your Vercel deployment URL)
# =============================================================================
NEXTAUTH_URL="https://your-app.vercel.app"

# =============================================================================
# AUTH (for when real auth is re-enabled)
# =============================================================================
# AUTH_SECRET=""         # openssl rand -base64 32
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
