# ─── Database ─────────────────────────────────────────────────
# For production, use Supabase or any PostgreSQL provider.
# DATABASE_URL uses PgBouncer (pooled); DIRECT_URL bypasses it for migrations.
DATABASE_URL="postgresql://user:password@host:5432/padda_legal?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://user:password@host:5432/padda_legal"

# ─── AI ───────────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# Get from: https://console.x.ai
GROK_API_KEY=""
GROK_BASE_URL="https://api.x.ai/v1"

# ─── Email (Resend) ───────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="Padda Legal <briefings@yourdomain.com>"
RESEND_ALERT_EMAIL="alerts@yourdomain.com"

# ─── SMS / Voice (Twilio) ─────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER="+17025550000"

# ─── Gmail OAuth ──────────────────────────────────────────────
# Get from: https://console.cloud.google.com (OAuth 2.0 credentials)
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REDIRECT_URI="https://yourdomain.com/api/auth/gmail/callback"
GMAIL_USER="your@gmail.com"

# ─── Google APIs ──────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# ─── QuickBooks ───────────────────────────────────────────────
# Get from: https://developer.intuit.com
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""
QUICKBOOKS_REALM_ID=""
QUICKBOOKS_ACCESS_TOKEN=""
QUICKBOOKS_REFRESH_TOKEN=""

# ─── DocuSign ─────────────────────────────────────────────────
# Get from: https://developers.docusign.com
DOCUSIGN_ACCOUNT_ID=""
DOCUSIGN_INTEGRATION_KEY=""
DOCUSIGN_SECRET_KEY=""
DOCUSIGN_BASE_URL="https://na4.docusign.net/restapi"

# ─── Cron Security ────────────────────────────────────────────
# A strong random secret to protect /api/cron/* endpoints.
# Vercel Cron jobs send this in the Authorization header.
CRON_SECRET="generate-a-strong-secret-here"

# ─── Auth (NextAuth) ──────────────────────────────────────────
# openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-strong-secret-here"
NEXTAUTH_URL="https://yourdomain.com"
